APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_INSTANCE_NAME=trainerboard-dev
APP_INSTANCE_ID=trainerboard-dev:8000
SERVE_FRONTEND=false
ALLOW_DEV_CORS=true
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
ENABLE_TERMINAL=true
TERMINAL_SSH_HOST=
TERMINAL_SSH_PORT=22
TERMINAL_SSH_USERNAME=
TERMINAL_SSH_PASSWORD=
TERMINAL_SSH_KEY_PATH=
TERMINAL_SSH_SHELL=/bin/bash -l
